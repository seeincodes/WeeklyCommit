{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/vitest.config.[jt]s",
      "!{projectRoot}/playwright.config.[jt]s",
      "!{projectRoot}/cypress.config.[jt]s",
      "!{projectRoot}/cypress/**/*",
      "!{projectRoot}/**/__tests__/**/*",
      "!{projectRoot}/.eslintrc.*",
      "!{projectRoot}/eslint.config.*"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/.editorconfig",
      "{workspaceRoot}/.nvmrc",
      "{workspaceRoot}/.tool-versions",
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/nx.json"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "test": {
      "inputs": ["default", "^production"],
      "cache": true
    },
    "test:unit": {
      "inputs": ["default", "^production"],
      "cache": true
    },
    "lint": {
      "inputs": ["default", "{workspaceRoot}/.eslintrc.json", "{workspaceRoot}/eslint.config.js"],
      "cache": true
    },
    "typecheck": {
      "inputs": ["default", "^production"],
      "cache": true
    },
    "e2e": {
      "inputs": ["default", "^production"],
      "cache": false
    }
  },
  "parallel": 3,
  "useInferencePlugins": false
}
