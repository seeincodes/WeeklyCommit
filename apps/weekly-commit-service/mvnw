#!/bin/sh
# ----------------------------------------------------------------------------
# Minimal Maven Wrapper launcher. Downloads and caches maven-wrapper.jar on
# first run, then delegates to it.
#
# Java resolution order:
#   1. $JAVA_HOME/bin/java   (only if it actually exists)
#   2. macOS: /usr/libexec/java_home -v 21   (the project's target)
#   3. `java` on PATH
# ----------------------------------------------------------------------------
set -e

SCRIPT_DIR="$( cd "$( dirname "$0" )" >/dev/null 2>&1 && pwd )"
PROPS="$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.properties"
JAR="$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.jar"

# --- find java ---
JAVA_CMD=""
if [ -n "$JAVA_HOME" ] && [ -x "$JAVA_HOME/bin/java" ]; then
    JAVA_CMD="$JAVA_HOME/bin/java"
elif [ "$(uname -s)" = "Darwin" ] && [ -x /usr/libexec/java_home ]; then
    # Prefer Java 21 (project target); fall back to any JDK.
    JAVA_HOME_21="$(/usr/libexec/java_home -v 21 2>/dev/null || true)"
    if [ -n "$JAVA_HOME_21" ] && [ -x "$JAVA_HOME_21/bin/java" ]; then
        JAVA_CMD="$JAVA_HOME_21/bin/java"
    else
        JAVA_HOME_ANY="$(/usr/libexec/java_home 2>/dev/null || true)"
        [ -n "$JAVA_HOME_ANY" ] && [ -x "$JAVA_HOME_ANY/bin/java" ] && JAVA_CMD="$JAVA_HOME_ANY/bin/java"
    fi
fi
if [ -z "$JAVA_CMD" ] && command -v java >/dev/null 2>&1; then
    JAVA_CMD="$(command -v java)"
fi
if [ -z "$JAVA_CMD" ]; then
    echo "ERROR: could not find a usable 'java' command." >&2
    echo "  \$JAVA_HOME=$JAVA_HOME" >&2
    echo "  Install Java 21 (see .tool-versions) and ensure \$JAVA_HOME points at it," >&2
    echo "  or add java to PATH." >&2
    exit 1
fi

# --- download wrapper jar on first use ---
if [ ! -f "$JAR" ]; then
    URL=$(grep '^wrapperUrl=' "$PROPS" | cut -d= -f2-)
    echo "Downloading maven-wrapper from $URL"
    curl -fsSL -o "$JAR" "$URL"
fi

exec "$JAVA_CMD" \
    -classpath "$JAR" \
    "-Dmaven.multiModuleProjectDirectory=$SCRIPT_DIR" \
    org.apache.maven.wrapper.MavenWrapperMain "$@"
