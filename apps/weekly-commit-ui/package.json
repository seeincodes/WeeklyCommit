{
  "name": "@wc/weekly-commit-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Weekly Commit remote — Vite 5 + React 18 + Module Federation.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist node_modules/.vite",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "test:playwright": "playwright test",
    "test:cypress": "cypress run",
    "test:cypress:open": "cypress open"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": "cypress/support/step_definitions/[filepart].{ts,js}",
    "json": {
      "enabled": false
    }
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "@sentry/react": "^8.30.0",
    "@wc/rtk-api-client": "workspace:*",
    "flowbite-react": "^0.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^20.1.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.4",
    "@eslint/js": "^9.10.0",
    "@originjs/vite-plugin-federation": "^1.3.5",
    "@playwright/test": "^1.47.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.0",
    "cypress": "^13.15.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.10.0",
    "eslint-plugin-react": "^7.36.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.10",
    "flowbite": "^2.5.0",
    "globals": "^15.9.0",
    "jose": "^5.9.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.0",
    "typescript": "5.6.2",
    "typescript-eslint": "^8.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
